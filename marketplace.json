{
  "name": "ai-plugins",
  "displayName": "AI Plugins for Claude Code",
  "description": "一套功能丰富的 Claude Code 插件集合，包含智能代码提交、代码审查和专家级代码审查顾问，旨在提升开发效率和代码质量。",
  "version": "0.2.0",
  "author": "chenquan",
  "license": "MIT",
  "repository": "https://github.com/chenquan/ai-plugins",
  "homepage": "https://github.com/chenquan/ai-plugins#readme",
  "bugs": "https://github.com/chenquan/ai-plugins/issues",

  "categories": [
    "productivity",
    "development",
    "code-quality",
    "git",
    "code-review"
  ],

  "keywords": [
    "git",
    "commit",
    "code-review",
    "code-quality",
    "security",
    "performance",
    "testing",
    "ai-assistant",
    "developer-tools",
    "productivity",
    "conventional-commits",
    "code-analysis",
    "best-practices",
    "team-training"
  ],

  "features": {
    "commands": [
      {
        "name": "/commit",
        "displayName": "智能提交",
        "description": "自动生成符合 Conventional Commits 规范的提交信息，支持 20+ 编程语言",
        "icon": "📝",
        "examples": [
          "/commit",
          "/commit --fix",
          "/commit --feat"
        ]
      },
      {
        "name": "/cr",
        "displayName": "代码审查",
        "description": "智能代码审查工具，支持 4 种审查模式和 20+ 编程语言",
        "icon": "🔍",
        "examples": [
          "/cr",
          "/cr src/main.go",
          "/cr --commit HEAD",
          "/cr --pr 123"
        ]
      }
    ],
    "agents": [
      {
        "name": "code-review-expert",
        "displayName": "代码审查专家",
        "description": "专家级代码审查顾问，提供深度分析、长期改进规划和团队培训建议",
        "icon": "🎓",
        "capabilities": [
          "深度代码分析",
          "根本原因分析",
          "问题模式识别",
          "架构洞察",
          "趋势分析",
          "改进路线图制定",
          "技术债务管理",
          "团队培训建议",
          "最佳实践推广"
        ]
      }
    ],
    "templates": [
      {
        "name": "review-tracker",
        "description": "问题跟踪模板"
      },
      {
        "name": "training-plan",
        "description": "团队培训计划模板"
      },
      {
        "name": "improvement-report",
        "description": "质量改进报告模板"
      }
    ]
  },

  "supportedLanguages": [
    "go",
    "java",
    "kotlin",
    "python",
    "javascript",
    "typescript",
    "c",
    "cpp",
    "csharp",
    "php",
    "ruby",
    "rust",
    "swift",
    "dart",
    "scala",
    "shell",
    "lua",
    "perl",
    "haskell"
  ],

  "requirements": {
    "claudeCode": ">=1.0.0",
    "optional": [
      {
        "tool": "gh",
        "description": "GitHub CLI for PR review support",
        "installUrl": "https://cli.github.com/"
      },
      {
        "tool": "git",
        "description": "Git version control",
        "installUrl": "https://git-scm.com/"
      }
    ]
  },

  "installation": {
    "cli": "npx @claude-code/plugins install ai-plugins",
    "manual": "git clone https://github.com/chenquan/ai-plugins.git ~/.claude/plugins/ai-plugins"
  },

  "changelog": {
    "0.2.0": [
      "添加代码审查专家代理 (code-review-expert)",
      "添加 20+ 编程语言的最佳实践知识库",
      "添加代码审查配置系统",
      "添加团队培训计划模板",
      "添加质量改进报告模板",
      "添加问题跟踪模板",
      "完善文档和使用指南"
    ],
    "0.1.0": [
      "初始版本发布",
      "实现 /commit 智能提交命令",
      "实现 /cr 代码审查命令",
      "支持 20+ 编程语言",
      "添加示例代理和技能"
    ]
  },

